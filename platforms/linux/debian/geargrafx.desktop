[Desktop Entry]
Type=Application
Name=Geargrafx
GenericName=PC Engine / TurboGrafx-16 emulator
Comment=Play PC Engine, TurboGrafx-16, SuperGrafx, and CD-ROM² games
Exec=/usr/games/geargrafx %f
TryExec=/usr/games/geargrafx
Icon=geargrafx
Terminal=false
MimeType=application/x-pc-engine-rom;application/x-supergrafx-rom;application/x-pc-engine-hes;
Categories=Game;Emulator;
Keywords=PC Engine;TurboGrafx-16;SuperGrafx;CD-ROM2;PCE;HuCard;
StartupNotify=true
